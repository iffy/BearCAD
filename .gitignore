# Compiled output
/target/

# OCCT static build output (#86); built on demand by scripts/build-occt.sh, never committed
/third_party/OCCT/occt-build/
/third_party/OCCT/occt-install/

# Local release packaging output
/dist/
/target/generated/
bearcad-*.tar.gz
bearcad-*.dmg
bearcad-*.exe
/bearcad.exe

# Backtrace/debug artifacts
*.pdb

# Editor/OS cruft
.DS_Store

# Local environment overrides
*.local

# These are backup files generated by rustfmt
**/*.rs.bk
.contai
.contai.config
.todoer
.mcp.json

# Issue monitor runtime state (scripts/bearcad-monitor.sh)
scripts/monitor-state/

# Auto-generated documentation screenshots (scripts/gen-doc-screenshots.sh).
# These are build artifacts: regenerated locally on demand and by the Website CI
# job before the Docusaurus build, never committed.
/docs-site/static/img/screenshots/
block.stl
block.step

# Web (wasm) build output; built by scripts/build-web.sh, deployed by CI
/web/dist/
/web/kernel/
/web/lua/
/docs-site/static/app/
